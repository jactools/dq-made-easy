ARG BASE_REGISTRY
FROM ${BASE_REGISTRY}python:3.14-slim

WORKDIR /app

COPY dq-api/scripts/generate_keycloak_realm.py /app/generate_keycloak_realm.py
COPY dq-db/mock-data /app/mock-data
COPY dq-keycloak/scripts/generate_seed_artifacts.sh /app/generate_seed_artifacts.sh

RUN chmod +x /app/generate_seed_artifacts.sh

ENTRYPOINT ["/app/generate_seed_artifacts.sh"]