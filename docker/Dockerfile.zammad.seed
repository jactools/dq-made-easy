# syntax=docker/dockerfile:1.7
FROM docker:cli AS docker-cli

FROM python:3.14-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /workspace

ARG PIP_INDEX_URL

COPY --from=docker-cli /usr/local/bin/docker /usr/local/bin/docker

RUN --mount=type=secret,id=internal_corporate_root_ca \
    set -eux; \
    cp /run/secrets/internal_corporate_root_ca /usr/local/share/ca-certificates/internal-corporate-root-ca2.crt; \
    update-ca-certificates; \
    for apt_sources in /etc/apt/sources.list /etc/apt/sources.list.d/*.list /etc/apt/sources.list.d/*.sources; do \
        [ -e "$apt_sources" ] || continue; \
        sed -i 's|http://|https://|g' "$apt_sources"; \
    done; \
    apt-get update \
    && apt-get install -y --no-install-recommends bash ca-certificates curl \
    && rm -f /usr/local/share/ca-certificates/internal-corporate-root-ca2.crt \
    && update-ca-certificates --fresh \
    && rm -rf /var/lib/apt/lists/*

COPY dq-api/fastapi/requirements.txt /tmp/requirements.txt
RUN PIP_INDEX_URL="$PIP_INDEX_URL" pip install --no-cache-dir -r /tmp/requirements.txt

COPY dq-domain-validation/pyproject.toml /tmp/dq-domain-validation/pyproject.toml
COPY dq-domain-validation/src /tmp/dq-domain-validation/src
COPY dq-utils/pyproject.toml /tmp/dq-utils/pyproject.toml
COPY dq-utils/src /tmp/dq-utils/src
RUN PIP_INDEX_URL="$PIP_INDEX_URL" pip install --no-cache-dir /tmp/dq-domain-validation /tmp/dq-utils

COPY dq-api/fastapi /workspace/dq-api/fastapi
COPY dq-api/scripts/update_support_itsm_token.py /workspace/dq-api/scripts/update_support_itsm_token.py
COPY dq-db/mock-data /workspace/dq-db/mock-data
COPY scripts/generate_zammad_autowizard.py /workspace/scripts/generate_zammad_autowizard.py
COPY scripts/generate_zammad_generated_users.py /workspace/scripts/generate_zammad_generated_users.py
COPY scripts/run_zammad_seed_container.sh /workspace/scripts/run_zammad_seed_container.sh
COPY scripts/supporting/logging.sh /workspace/scripts/supporting/logging.sh
COPY scripts/supporting/logging/core.sh /workspace/scripts/supporting/logging/core.sh
COPY scripts/supporting/keycloak_readiness.sh /workspace/scripts/supporting/keycloak_readiness.sh
COPY scripts/supporting/readiness.sh /workspace/scripts/supporting/readiness.sh

RUN chmod +x /workspace/scripts/run_zammad_seed_container.sh

ENTRYPOINT ["/workspace/scripts/run_zammad_seed_container.sh"]