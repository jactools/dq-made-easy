      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "sum by (role) (increase(dq_api_auth_login_total{role=~\"admin|auditor|regulator\"}[5m]))",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ],
      "title": "Role Logins Over Time",
      "type": "timeseries"
