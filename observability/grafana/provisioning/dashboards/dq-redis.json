      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "mean"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "sum by (source, operation_type, status) (label_replace(increase({__name__=~\"dq_.+_redis_request_count_total\",operation_type!=\"brpop\"}[5m]), \"source\", \"$1\", \"__name__\", \"dq_(.+)_redis_request_count_total\"))",
          "refId": "A",
          "legendFormat": "{{source}} {{operation_type}} / {{status}}"
        }
      ],
      "title": "Redis Operations by Source (5m)",
      "type": "timeseries"
    },
