# Profile: engine + workers + AIStor
DQ_ENGINE_OIDC_CLIENT_ID=dq-made-easy-engine-gx-worker
DQ_ENGINE_OIDC_CLIENT_SECRET=changeme
DQ_ENGINE_POLLING_INTERVAL_MS=5000
DQ_ENGINE_MAX_RETRIES=3
