DQ_SPARK_INCLUDE_LARGE_JARS=0

DQ_TEST_DATA_OUTPUT_PREFIX=s3a://dq-test-data
DQ_S3_ENDPOINT=http://aistor:9000
DQ_S3_ACCESS_KEY=aistoradmin
DQ_S3_SECRET_KEY=aistoradmin
