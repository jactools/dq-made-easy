# Data Quality Made Easy - Test Environment Template
# Copy this file to .env.test.local and fill the placeholder hostnames, TLS files,
# and secrets for the canonical isolated local test environment.
# Version: 0.9.3
# Sections follow docker-compose profiles where possible. Shared build and image
# settings remain at the top because they apply across multiple profiles.


ROOT_ENV_FILE=.env.test.example

REGISTRY=docker.io/
DOCKER_DOMAIN=docker.io

# Nexus Cloud registry/auth references
NEXUSCLOUD_HOSTNAME=__SET_NEXUSCLOUD_HOSTNAME__
NEXUSCLOUD_DNS=//${NEXUSCLOUD_HOSTNAME}
NEXUSCLOUD_REGISTRY=https://${NEXUSCLOUD_HOSTNAME}/repository/npmjs-org/
NEXUSCLOUD_NPM_REPOSITORY=gr-npm-84
NEXUSCLOUD_NPM_REGISTRY=https://${NEXUSCLOUD_HOSTNAME}/repository/${NEXUSCLOUD_NPM_REPOSITORY}/
NEXUSCLOUD_PYPI_GROUP_REPO=gr-pypi-36
NEXUSCLOUD_USERNAME=__SET_NEXUSCLOUD_USERNAME__
NEXUSCLOUD_PASSWORD=__SET_NEXUSCLOUD_PASSWORD__
NEXUSCLOUD_PASSWORD_BASE64=__SET_NEXUSCLOUD_PASSWORD_BASE64__

# Shared Docker image sources and build inputs
PG_REGISTRY=${REGISTRY}
PG_NAMESPACE=
PG_IMAGE=postgres
PG_TAG=15

KEYCLOAK_REGISTRY=${REGISTRY}
KEYCLOAK_NAMESPACE=keycloak/
KEYCLOAK_IMAGE=keycloak
KEYCLOAK_TAG=23.0

NODE_REGISTRY=${REGISTRY}
NODE_NAMESPACE=
NODE_IMAGE=node
# Example tags:
# - Debian-based: 25-trixie-slim
# - Alpine-based: 25-alpine
NODE_TAG=20-bullseye-slim
# Optional Alpine package mirror override.
APK_REPOSITORIES=

NGINX_REGISTRY=${REGISTRY}
NGINX_NAMESPACE=
NGINX_IMAGE=nginx
NGINX_TAG=stable-alpine

REDIS_REGISTRY=${REGISTRY}
REDIS_NAMESPACE=
REDIS_IMAGE=redis
REDIS_TAG=7-alpine

# Built application images
DQ_BASE_REGISTRY=docker.io/
DQ_BASE_NAMESPACE=yournamespace/
DQ_BASE_IMAGE=dq-made-easy-base
DQ_BASE_TAG=0.10-566577b

DQ_API_REGISTRY=docker.io/
DQ_API_NAMESPACE=yournamespace/
DQ_API_IMAGE=dq-made-easy-api
DQ_API_TAG=0.10-7a9c018

DQ_ENGINE_REGISTRY=docker.io/
DQ_ENGINE_NAMESPACE=yournamespace/
DQ_ENGINE_IMAGE=dq-made-easy-engine
DQ_ENGINE_TAG=0.10-b745035

DQ_PROFILING_REGISTRY=docker.io/
DQ_PROFILING_NAMESPACE=yournamespace/
DQ_PROFILING_IMAGE=dq-made-easy-profiling
DQ_PROFILING_TAG=0.10-950d35e

DQ_FRONTEND_REGISTRY=docker.io/
DQ_FRONTEND_NAMESPACE=yournamespace/
DQ_FRONTEND_IMAGE=dq-made-easy-frontend
DQ_FRONTEND_TAG=0.10-bd861ee

DQ_KONG_REGISTRY=docker.io/
DQ_KONG_NAMESPACE=yournamespace/
DQ_KONG_IMAGE=dq-made-easy-kong
DQ_KONG_TAG=0.10-18a1248

DQ_KEYCLOAK_REGISTRY=docker.io/
DQ_KEYCLOAK_NAMESPACE=yournamespace/
DQ_KEYCLOAK_IMAGE=dq-made-easy-keycloak
DQ_KEYCLOAK_TAG=0.10-af03ed8

DQ_DB_REGISTRY=docker.io/
DQ_DB_NAMESPACE=yournamespace/
DQ_DB_IMAGE=dq-made-easy-db
DQ_DB_TAG=0.10-49540d2

DQ_LLM_REGISTRY=docker.io/
DQ_LLM_NAMESPACE=yournamespace/
DQ_LLM_IMAGE=dq-made-easy-llm
DQ_LLM_TAG=0.10-464630c

# Shared runtime
ENVIRONMENT=test
COMPOSE_PROJECT_NAME=dq-made-easy-test
PIP_INDEX_URL=
MAVEN_REPOSITORIES=
NODE_ENV=production
MKCERT_ROOT_CA=
INTERNAL_ROOT_CA=
INTERNAL_CORPORATE_ROOT_CA=
OTEL_JAVAAGENT_VERSION=2.16.0
APP_DISPLAY_NAME="Data Quality Made Easy"
LOCAL_APP_HOST=__SET_LOCAL_APP_HOST__
LOCAL_KONG_HOST=__SET_LOCAL_KONG_HOST__
LOCAL_KEYCLOAK_HOST=__SET_LOCAL_KEYCLOAK_HOST__
LOCAL_OPENMETADATA_HOST=__SET_LOCAL_OPENMETADATA_HOST__
LOCAL_OBSERVABILITY_HOST=__SET_LOCAL_OBSERVABILITY_HOST__
LOCAL_SUPPORT_HOST=__SET_LOCAL_SUPPORT_HOST__
LOCAL_AIRFLOW_HOST=__SET_LOCAL_AIRFLOW_HOST__

# Profile: core + redis
DQ_DB_HOST=127.0.0.1
DATABASE_SCHEMA=dq
DQ_DB_INTERNAL_URL=postgresql://postgres:postgres@db:5432/dq
DQ_DB_LOCAL_URL=postgresql://postgres:postgres@127.0.0.1:15432/${DATABASE_SCHEMA}
DB_CONTAINER=${COMPOSE_PROJECT_NAME}-db-1
DB_HOST_BIND=0.0.0.0
DB_HOST_PORT=15432
REDIS_HOST_BIND=0.0.0.0
REDIS_HOST_PORT=16379

# Profile: llm
DQ_LLM_HOST_BIND=127.0.0.1
DQ_LLM_HOST_PORT=18123
DQ_LLM_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
DQ_LLM_DEVICE_MAP=auto
DQ_LLM_MAX_NEW_TOKENS=512
DQ_LLM_CHAT_PROVIDER=huggingface
DQ_LLM_OLLAMA_BASE_URL=
DQ_LLM_OLLAMA_MODEL=gemma3:4b
DQ_LLM_OLLAMA_TIMEOUT_SECONDS=180
# Switch to meta-llama/Meta-Llama-3.1-8B-Instruct when the model access is available.
# To use Ollama instead of local Hugging Face loading, set DQ_LLM_CHAT_PROVIDER=ollama and configure the Ollama base URL and model.

# Profile: auth + gateway
# Fill the placeholder hostnames before using this template.
APP_CONFIG_ENCRYPTION_KEY=
EDGE_MODE=local
EDGE_LOCAL_APP_HOST=${LOCAL_APP_HOST}
EDGE_LOCAL_KONG_HOST=${LOCAL_KONG_HOST}
EDGE_LOCAL_KEYCLOAK_HOST=${LOCAL_KEYCLOAK_HOST}
EDGE_LOCAL_OPENMETADATA_HOST=${LOCAL_OPENMETADATA_HOST}
EDGE_LOCAL_OBSERVABILITY_HOST=${LOCAL_OBSERVABILITY_HOST}
EDGE_LOCAL_SUPPORT_HOST=${LOCAL_SUPPORT_HOST}
EDGE_LOCAL_AIRFLOW_HOST=${LOCAL_AIRFLOW_HOST}
COMPOSE_PROFILES=support,zammad-direct-https
EDGE_BIND_HOST=0.0.0.0
EDGE_PUBLIC_PORT=15443
EDGE_SSL_CERTS_DIR=./tmp/certs
EDGE_SSL_CERT_FILE_NAME=__SET_EDGE_CERT_FILE__
EDGE_SSL_KEY_FILE_NAME=__SET_EDGE_KEY_FILE__

API_HOST_BIND=0.0.0.0
API_HOST_PORT=14010
FRONTEND_HOST_BIND=0.0.0.0
FRONTEND_HTTPS_HOST_PORT=15173
KEYCLOAK_HTTP_HOST_BIND=0.0.0.0
KEYCLOAK_HTTP_HOST_PORT=18080
KEYCLOAK_HTTPS_HOST_BIND=0.0.0.0
KEYCLOAK_HTTPS_HOST_PORT=19444
KONG_PROXY_HOST_BIND=0.0.0.0
KONG_PROXY_HOST_PORT=19443
KONG_ADMIN_HOST_BIND=0.0.0.0
KONG_ADMIN_HOST_PORT=18001
KONG_MANAGER_HOST_BIND=0.0.0.0
KONG_MANAGER_HOST_PORT=18002
OPENMETADATA_HOST_BIND=0.0.0.0
OPENMETADATA_HOST_PORT=18585
GRAFANA_HOST_BIND=0.0.0.0
GRAFANA_HOST_PORT=13000
OPENMETADATA_DB_HOST_BIND=0.0.0.0
OPENMETADATA_DB_HOST_PORT=23306
OPENMETADATA_SEARCH_HOST_BIND=0.0.0.0
OPENMETADATA_SEARCH_HOST_PORT=29200
OPENMETADATA_INGESTION_HOST_BIND=0.0.0.0
OPENMETADATA_INGESTION_HOST_PORT=28080
LOKI_HOST_BIND=0.0.0.0
LOKI_HOST_PORT=13100
PROMETHEUS_HOST_BIND=0.0.0.0
PROMETHEUS_HOST_PORT=19090
TEMPO_HOST_BIND=0.0.0.0
TEMPO_HOST_PORT=13200
CONTAINER_METRICS_HOST_BIND=0.0.0.0
CONTAINER_METRICS_HOST_PORT=18881
PUSHGATEWAY_HOST_BIND=0.0.0.0
PUSHGATEWAY_HOST_PORT=19091
OTEL_GRPC_HOST_BIND=0.0.0.0
OTEL_GRPC_HOST_PORT=14317
OTEL_HTTP_HOST_BIND=0.0.0.0
OTEL_HTTP_HOST_PORT=14318
OTEL_JAEGER_HOST_BIND=0.0.0.0
OTEL_JAEGER_HOST_PORT=24250
OTEL_ZIPKIN_HOST_BIND=0.0.0.0
OTEL_ZIPKIN_HOST_PORT=19411
AISTOR_API_HOST_BIND=0.0.0.0
AISTOR_API_HOST_PORT=19222
AISTOR_CONSOLE_HOST_BIND=0.0.0.0
AISTOR_CONSOLE_HOST_PORT=19001
AISTOR_LICENSE_FILE=./tmp/aistor/minio.license
AISTOR_ROOT_USER=aistoradmin
AISTOR_ROOT_PASSWORD=aistoradmin
ZAMMAD_HOST_BIND=0.0.0.0
OIDC_REDIRECT_BASE_URL=https://${LOCAL_APP_HOST}:15173

KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_LOCAL_URL=https://${LOCAL_KEYCLOAK_HOST}:19444
KEYCLOAK_PUBLIC_HOSTNAME=${LOCAL_KEYCLOAK_HOST}
KEYCLOAK_PUBLIC_URL=https://${LOCAL_KEYCLOAK_HOST}:19444
KEYCLOAK_HTTP_RELATIVE_PATH=/
KEYCLOAK_HTTPS_KEYSTORE_PASSWORD=changeit

KEYCLOAK_ADMIN_ID=admin-cli
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASS=replace-with-strong-keycloak-admin-password
KEYCLOAK_DOMAIN=example.local

KEYCLOAK_REALM=jaccloud
KEYCLOAK_REALM_DISPLAY_NAME="Jaccloud Realm"
KEYCLOAK_JACCLOUD_USERNAME=alice@jaccloud.nl
KEYCLOAK_JACCLOUD_PASSWORD=replace-with-current-generated-password-from-keycloak-seed-user-credentials-env
KEYCLOAK_CLIENT_ID=dq-rules-ui
KEYCLOAK_NETWORK=${COMPOSE_PROJECT_NAME}_default
KEYCLOAK_HOST=keycloak:8080
KEYCLOAK_TOKEN_REALM=master
KEYCLOAK_SYSTEM_ADMIN_USERNAME=admin
KEYCLOAK_SYSTEM_ADMIN_PASSWORD=${KEYCLOAK_ADMIN_PASS}

SSO_PROVIDER=keycloak
SSO_ENABLED=true
SSO_PUBLIC_ISSUER_URL=https://${LOCAL_KEYCLOAK_HOST}:19444/realms/jaccloud
SSO_CLIENT_ID=dq-rules-ui
SSO_ALLOWED_CLIENT_IDS=dq-rules-ui,dq-made-easy-engine-gx-worker,grafana
GRAFANA_OIDC_REALM_ROLE=dq:rules:read
SSO_INTERNAL_ISSUER_URL=http://keycloak:8080/realms/jaccloud
ALLOW_LOCAL_AUTH=false
SMOKE_LOGIN_EMAIL=dq-admin@jaccloud.nl
OPERATOR_LOGIN_EMAIL=operator@jaccloud.nl
AUDITOR_LOGIN_EMAIL=auditor@jaccloud.nl
REGULATOR_LOGIN_EMAIL=regulator@jaccloud.nl

# Profile: airflow
AIRFLOW_HOST_BIND=127.0.0.1
AIRFLOW_HOST_PORT=18088
AIRFLOW_FAB_CLIENT_ID=airflow
AIRFLOW_FAB_CLIENT_SECRET=changeme
DQ_AIRFLOW_BASE_URL=http://api:4010
DQ_AIRFLOW_ISSUER_URL=${SSO_INTERNAL_ISSUER_URL}
DQ_AIRFLOW_CLIENT_ID=${SSO_CLIENT_ID}
DQ_AIRFLOW_USERNAME=${OPERATOR_LOGIN_EMAIL:-${KEYCLOAK_JACCLOUD_USERNAME}}
DQ_AIRFLOW_PASSWORD=${OPERATOR_LOGIN_PASSWORD:-${KEYCLOAK_JACCLOUD_PASSWORD}}
DQ_AIRFLOW_RUN_PLAN_ID=
DQ_AIRFLOW_SOURCE_PIPELINE=airflow
DQ_AIRFLOW_WAIT_TIMEOUT_SECONDS=1800
DQ_AIRFLOW_POLL_INTERVAL_SECONDS=5

KONG_INTERNAL_URL=http://kong:8000
KONG_ADMIN_INTERNAL_URL=http://kong:8001
KONG_LOCAL_URL=https://${LOCAL_KONG_HOST}:19443
KONG_PUBLIC_URL=https://${LOCAL_KONG_HOST}:19443
KONG_ADMIN_LOCAL_URL=http://${LOCAL_KONG_HOST}:18001
KONG_ADMIN_PUBLIC_URL=http://${LOCAL_KONG_HOST}:18001
KONG_MANAGER_LOCAL_URL=http://${LOCAL_KONG_HOST}:18002
KONG_MANAGER_PUBLIC_URL=http://${LOCAL_KONG_HOST}:18002
KONG_ADMIN_USERNAME=kong
KONG_ADMIN_PASSWORD=kong

DQ_API_INTERNAL_URL=http://api:4010
DQ_API_LOCAL_URL=http://127.0.0.1:14010
KEYCLOAK_ADMIN_REALM=master
TRUST_PROXY_AUTH=true
KONG_TRACING_INSTRUMENTATIONS=all
KONG_TRACING_SAMPLING_RATE=0.1
KONG_OTEL_ENDPOINT=http://dq-otel-collector:4319/v1/traces

# Frontend settings
UI_VITE_LOCAL_URL=https://${LOCAL_APP_HOST}:15174
UI_NGINX_LOCAL_URL=https://${LOCAL_APP_HOST}:15173
VITE_HOST=0.0.0.0
VITE_PORT=15174
VITE_HTTPS_KEY_FILE=../tmp/certs/__SET_VITE_CERT_KEY_FILE__
VITE_HTTPS_CERT_FILE=../tmp/certs/__SET_VITE_CERT_FILE__
VITE_KEYCLOAK_REALM=jaccloud
VITE_KEYCLOAK_CLIENT_ID=dq-rules-ui
VITE_SSO_PROVIDER=keycloak
VITE_SSO_ENABLED=${SSO_ENABLED}
VITE_SSO_ISSUER_URL=${SSO_PUBLIC_ISSUER_URL}
VITE_SSO_CLIENT_ID=dq-rules-ui
VITE_ALLOW_LOCAL_AUTH=${ALLOW_LOCAL_AUTH}
VITE_OTEL_ENABLED=true
VITE_OTEL_ENDPOINT=https://${LOCAL_APP_HOST}/observability/otlp
VITE_HMR_HOST=https://${LOCAL_APP_HOST}:15174
