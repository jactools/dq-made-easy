ZAMMAD_EXPOSE_PORT=18088
ZAMMAD_PUBLIC_URL=https://${LOCAL_SUPPORT_HOST}:${ZAMMAD_EXPOSE_PORT}
TZ=UTC

# Publish-only credentials
DOCKER_HUB_USERNAME=
DOCKER_HUB_TOKEN=

# Notes
# - Build order: base -> api -> engine -> profiling -> frontend
# - dq-ui build requires dq-ui/dist/ to exist before image builds.
# - Authenticate before pushing to Docker Hub: docker login docker.io

DQ_DATA_DEFINITION_EVENT_TIMEOUT_SECONDS=900
DQ_DATA_DEFINITION_LLM_TIMEOUT_SECONDS=900
DQ_SMOKE_MATERIALIZATION_TIMEOUT_SECONDS=900
DQ_RULE_E2E_MATERIALIZATION_TIMEOUT_SECONDS=900
DQ_RULE_E2E_GX_TIMEOUT_SECONDS=900
DQ_LLM_MAX_RETRIES=3
DQ_MCP_API_BASE_URL=${DQ_API_LOCAL_URL}/api
DQ_MCP_API_TOKEN=
DQ_MCP_API_TIMEOUT_SECONDS=30
