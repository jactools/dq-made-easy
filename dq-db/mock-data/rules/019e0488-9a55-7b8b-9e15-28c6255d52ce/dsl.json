{
  "schema_version": "2.0.0",
  "rule": {
    "kind": "freshness_assertion",
    "scope": {
      "dataset": {
        "data_object_id": "do-transaction"
      }
    },
    "measure": {
      "type": "metric",
      "metric": "freshness_age",
      "subject": {
        "column": "transaction_date"
      }
    },
    "expectation": {
      "type": "threshold",
      "operator": "lte",
      "value": "P30D",
      "unit": "duration"
    },
    "evidence": {
      "failed_rows": {
        "mode": "sample",
        "limit": 25,
        "include_row_identifier": true,
        "include_primary_key": true
      },
      "emit_compiled_artifact": true,
      "emit_generated_sql": false
    },
    "operations": {
      "severity": "critical",
      "preferred_engines": [
        "gx",
        "sql"
      ],
      "fail_if_not_native": false
    }
  }
}
