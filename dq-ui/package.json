{
  "name": "dq-ui",
  "version": "0.11.5",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.14.1",
  "scripts": {
    "docs:build": "bash scripts/build-public-docs.sh",
    "build:style-packages": "node scripts/build-style-packages.mjs",
    "watch:style-packages": "node scripts/watch-style-packages.mjs",
    "predev": "bash scripts/build-public-docs.sh && node scripts/sync-adrs.mjs && bash scripts/sync-user-manuals.sh && npm run build:style-packages",
    "dev": "vite",
    "prebuild": "bash scripts/build-public-docs.sh && node scripts/sync-adrs.mjs && bash scripts/sync-user-manuals.sh && npm run build:style-packages",
    "build": "vite build 2>&1 | grep -E 'error|warn|failed|success|vite v|Build' || true",
    "preview": "vite preview",
    "test": "NODE_ENV=test vitest run"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/context-zone": "2.6.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.213.0",
    "@opentelemetry/instrumentation-fetch": "0.213.0",
    "@opentelemetry/instrumentation-xml-http-request": "0.213.0",
    "@opentelemetry/sdk-metrics": "2.6.0",
    "@opentelemetry/sdk-trace-base": "2.6.0",
    "@opentelemetry/sdk-trace-web": "2.6.0",
    "@tabler/icons-react": "^3.44.0",
    "keycloak-js": "26.2.3",
    "lucide-react": "^1.17.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.3.0",
    "playwright": "^1.53.0",
    "postcss": "^8.5.8",
    "typescript": "^5.1.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
