{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dq-made-easy.local/contracts/rule-dsl/2.0.0/schema.json",
  "title": "Rule DSL Authoring Request 2.0.0",
  "description": "Canonical engine-independent rule authoring contract for dq-made-easy. The payload captures semantic rule intent and leaves runtime lowering to backend compiler stages.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "dimension",
    "active",
    "workspace",
    "dsl"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable rule name."
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Optional human-readable rule description."
    },
    "dimension": {
      "type": "string",
      "minLength": 1,
      "description": "Business quality dimension, such as completeness or validity."
    },
    "active": {
      "type": "boolean",
      "description": "Whether the rule should be active after write."
    },
    "workspace": {
      "type": "string",
      "minLength": 1,
      "description": "Workspace identifier for the rule."
    },
    "generated": {
      "type": "boolean",
      "description": "Whether the rule was generated by a repo-controlled assistant flow."
    },
    "dsl": {
      "$ref": "#/$defs/dslEnvelope"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringOrNull": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "engineTarget": {
      "type": "string",
      "enum": [
        "gx",
        "sodacl",
        "sql",
        "pyspark_native",
        "custom_worker"
      ]
    },
    "dslEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "rule"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "2.0.0",
          "description": "Canonical semantic DSL schema version."
        },
        "rule": {
          "$ref": "#/$defs/ruleDocument"
        }
      }
    },
    "ruleDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "scope",
        "measure",
        "expectation",
        "evidence",
        "operations"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "row_assertion",
            "metric_threshold",
            "metric_comparison",
            "schema_assertion",
            "reference_assertion",
            "reconciliation_assertion",
            "freshness_assertion",
            "distribution_assertion",
            "anomaly_assertion",
            "custom_query_assertion"
          ],
          "description": "Semantic rule family."
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "measure": {
          "$ref": "#/$defs/measure"
        },
        "expectation": {
          "$ref": "#/$defs/expectation"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "operations": {
          "$ref": "#/$defs/operations"
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "dataset": {
          "$ref": "#/$defs/datasetScope"
        },
        "row_filter": {
          "$ref": "#/$defs/predicate"
        },
        "join": {
          "$ref": "#/$defs/joinScope"
        },
        "grouping": {
          "$ref": "#/$defs/groupingScope"
        },
        "time_window": {
          "$ref": "#/$defs/timeWindow"
        },
        "comparison": {
          "$ref": "#/$defs/comparisonScope"
        }
      }
    },
    "datasetScope": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "data_object_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "data_object_version_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "dataset_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "data_product_id": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "language",
        "expression"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "row_predicate"
        },
        "language": {
          "type": "string",
          "enum": [
            "dq_predicate",
            "sql"
          ]
        },
        "expression": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "joinCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "left_column",
        "operator",
        "right_column"
      ],
      "properties": {
        "left_column": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "operator": {
          "type": "string",
          "enum": [
            "=",
            "!=",
            ">",
            ">=",
            "<",
            "<="
          ]
        },
        "right_column": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "joinScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "join_type",
        "conditions"
      ],
      "properties": {
        "join_type": {
          "type": "string",
          "enum": [
            "inner",
            "left",
            "right",
            "full"
          ]
        },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/joinCondition"
          }
        }
      }
    },
    "groupingScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keys"
      ],
      "properties": {
        "keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "uniqueItems": true
        }
      }
    },
    "timeWindow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "anchor_column": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "trailing_duration": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "leading_duration": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "joinKey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "left_column",
        "right_column"
      ],
      "properties": {
        "left_column": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "right_column": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "comparisonScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "left",
        "right"
      ],
      "properties": {
        "left": {
          "$ref": "#/$defs/datasetScope"
        },
        "right": {
          "$ref": "#/$defs/datasetScope"
        },
        "join_keys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/joinKey"
          }
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "column": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "uniqueItems": true
        }
      }
    },
    "rowPredicateMeasure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "predicate"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "row_predicate"
        },
        "predicate": {
          "$ref": "#/$defs/predicate"
        }
      }
    },
    "metricMeasure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "metric"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "metric"
        },
        "metric": {
          "type": "string",
          "enum": [
            "row_count",
            "missing_count",
            "missing_percent",
            "duplicate_count",
            "duplicate_percent",
            "distinct_count",
            "min",
            "max",
            "avg",
            "sum",
            "stddev",
            "quantile",
            "freshness_age",
            "match_percent"
          ]
        },
        "subject": {
          "$ref": "#/$defs/subject"
        }
      }
    },
    "schemaMeasure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "schema_assertion"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "schema"
        },
        "schema_assertion": {
          "type": "string",
          "enum": [
            "required_columns_present",
            "forbidden_columns_absent",
            "column_types_match",
            "column_count_between",
            "column_order_matches"
          ]
        }
      }
    },
    "queryMeasure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "query_language",
        "query"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "query"
        },
        "query_language": {
          "type": "string",
          "const": "sql"
        },
        "query": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "measure": {
      "oneOf": [
        {
          "$ref": "#/$defs/rowPredicateMeasure"
        },
        {
          "$ref": "#/$defs/metricMeasure"
        },
        {
          "$ref": "#/$defs/schemaMeasure"
        },
        {
          "$ref": "#/$defs/queryMeasure"
        }
      ]
    },
    "thresholdExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "operator"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "threshold"
        },
        "operator": {
          "type": "string",
          "enum": [
            "gt",
            "gte",
            "lt",
            "lte",
            "between"
          ]
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "min_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "max_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "unit": {
          "type": "string",
          "enum": [
            "count",
            "percent",
            "duration",
            "raw"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "operator": {
                "const": "between"
              }
            }
          },
          "then": {
            "required": [
              "min_value",
              "max_value"
            ]
          },
          "else": {
            "required": [
              "value"
            ]
          }
        }
      ]
    },
    "equalityExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "mode"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "equality"
        },
        "mode": {
          "type": "string",
          "enum": [
            "exact",
            "case_insensitive",
            "numeric_tolerance"
          ]
        },
        "tolerance": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "setMembershipExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "set_membership"
        },
        "allowed_values": {
          "$ref": "#/$defs/stringArray"
        },
        "blocked_values": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "anyOf": [
        {
          "required": [
            "allowed_values"
          ]
        },
        {
          "required": [
            "blocked_values"
          ]
        }
      ]
    },
    "schemaContractExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "schema_contract"
        },
        "required_columns": {
          "$ref": "#/$defs/stringArray"
        },
        "forbidden_columns": {
          "$ref": "#/$defs/stringArray"
        },
        "expected_types": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "min_column_count": {
          "type": "integer",
          "minimum": 0
        },
        "max_column_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "baselineExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "strategy"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "baseline"
        },
        "strategy": {
          "type": "string",
          "enum": [
            "dynamic_parameters",
            "forecast",
            "historical_band"
          ]
        },
        "lookback_runs": {
          "type": "integer",
          "minimum": 1
        },
        "sensitivity": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "expectation": {
      "oneOf": [
        {
          "$ref": "#/$defs/thresholdExpectation"
        },
        {
          "$ref": "#/$defs/equalityExpectation"
        },
        {
          "$ref": "#/$defs/setMembershipExpectation"
        },
        {
          "$ref": "#/$defs/schemaContractExpectation"
        },
        {
          "$ref": "#/$defs/baselineExpectation"
        }
      ]
    },
    "failedRowsPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "include_row_identifier",
        "include_primary_key"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "sample",
            "all_with_limit"
          ]
        },
        "limit": {
          "type": "integer",
          "minimum": 1
        },
        "include_row_identifier": {
          "type": "boolean"
        },
        "include_primary_key": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "enum": [
                  "sample",
                  "all_with_limit"
                ]
              }
            }
          },
          "then": {
            "required": [
              "limit"
            ]
          }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failed_rows",
        "emit_compiled_artifact",
        "emit_generated_sql"
      ],
      "properties": {
        "failed_rows": {
          "$ref": "#/$defs/failedRowsPolicy"
        },
        "emit_compiled_artifact": {
          "type": "boolean"
        },
        "emit_generated_sql": {
          "type": "boolean"
        }
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "preferred_engines",
        "fail_if_not_native"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "critical",
            "warning",
            "info"
          ]
        },
        "preferred_engines": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/engineTarget"
          },
          "uniqueItems": true
        },
        "fail_if_not_native": {
          "type": "boolean"
        }
      }
    }
  }
}