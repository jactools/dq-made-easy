  "paths": {
    "/api/system/v1/api-metrics": {
      "get": {
        "description": "Return API request metrics aggregated from the in-process store.\n\nFiltering is applied based on the Application Settings:\n- ``logLevel``              \u2014 controls which error statuses appear in\n                              *recentErrors* (error\u21925xx, warn/info\u21924xx+5xx,\n                              debug\u2192all)\n- ``auditLogRetentionDays`` \u2014 only include requests recorded within this\n                              many days",
        "operationId": "get_api_metrics_api_system_v1_api_metrics_get",
        "parameters": [
          {
            "in": "query",
            "name": "apiEndpointFilter",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Apiendpointfilter"
            }
          },
          {
            "in": "query",
            "name": "apiMethodFilter",
            "required": false,
            "schema": {
              "default": "all",
              "title": "Apimethodfilter",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "apiMinRequests",
            "required": false,
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "Apiminrequests",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "recentErrorStatusFilter",
            "required": false,
            "schema": {
              "default": "all",
              "title": "Recenterrorstatusfilter",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "recentErrorPathFilter",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Recenterrorpathfilter"
            }
          },
          {
            "in": "query",
            "name": "excludeHealthEndpoints",
            "required": false,
            "schema": {
              "default": false,
              "title": "Excludehealthendpoints",
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Get Api Metrics Api System V1 Api Metrics Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Api Metrics",
        "tags": [
          "system"
        ]
      }
    },
