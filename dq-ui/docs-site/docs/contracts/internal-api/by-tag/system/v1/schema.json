    "ValidationError": {
      "properties": {
        "ctx": {
          "title": "Context",
          "type": "object"
        },
        "input": {
          "title": "Input"
        },
        "loc": {
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              }
            ]
          },
          "title": "Location",
          "type": "array"
        },
        "msg": {
          "title": "Message",
          "type": "string"
        },
        "type": {
          "title": "Error Type",
          "type": "string"
        }
