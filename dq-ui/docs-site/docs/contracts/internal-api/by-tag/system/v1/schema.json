          "title": "Ui",
          "type": "string"
        }
      },
      "required": [
        "ui",
        "api"
      ],
      "title": "VersionCatalogAppView",
      "type": "object"
    },
    "VersionCatalogView": {
      "properties": {
        "apps": {
          "$ref": "#/$defs/VersionCatalogAppView"
        },
        "components": {
