      "properties": {
        "detail": {
          "items": {
            "$ref": "#/$defs/ValidationError"
          },
          "title": "Detail",
          "type": "array"
        }
      },
      "title": "HTTPValidationError",
      "type": "object"
    },
    "SystemInfoView": {
      "properties": {
        "api": {
          "$ref": "#/$defs/ApiInfoView"
        },
        "database": {
          "$ref": "#/$defs/DatabaseInfoView"
        },
        "deployment": {
          "$ref": "#/$defs/DeploymentInfoView"
