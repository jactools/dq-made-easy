          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Schema Git Commit"
        },
        "schema_updated": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Schema Updated"
        },
        "schema_version": {
          "title": "Schema Version",
