FROM python:3.14-slim AS builder

WORKDIR /app
ARG PIP_INDEX_URL
RUN set -eux; \
	apt-get update && apt-get install -y --no-install-recommends \
		git \
		build-essential \
                cmake \
                curl \
                wget \
                ca-certificates \
                libssl-dev \
                && rm -rf /var/lib/apt/lists/*

ENV HF_HOME=/cache/huggingface
RUN mkdir -p /cache/huggingface

COPY requirements.txt .
# llama-cpp-python is built from source; CMAKE_ARGS enables OpenSSL so the
# library links against the system libssl (already present via libssl-dev).
RUN PIP_CERT=/etc/ssl/certs/ca-certificates.crt \
    PIP_INDEX_URL="$PIP_INDEX_URL" \
    CMAKE_ARGS="-DLLAMA_SSL=ON" \
    pip install --no-cache-dir -r requirements.txt

COPY . .

FROM python:3.14-slim AS runtime

WORKDIR /app
ARG PIP_INDEX_URL
RUN set -eux; \
        apt-get update && apt-get install -y --no-install-recommends \
                git \
                build-essential \
                curl \
                wget \
                ca-certificates \
                libssl3 \
                && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/bin /usr/local/bin

EXPOSE 8000

CMD ["python", "entrypoint.py"]
