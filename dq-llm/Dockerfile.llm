FROM python:3.14-slim AS builder

WORKDIR /app
ARG PIP_INDEX_URL
RUN set -eux; \
	apt-get update && apt-get install -y --no-install-recommends \
		git \
		build-essential \
		curl \
		wget \
		ca-certificates \
		&& rm -rf /var/lib/apt/lists/*

ENV HF_HOME=/cache/huggingface
RUN mkdir -p /cache/huggingface

COPY requirements.txt .
RUN PIP_CERT=/etc/ssl/certs/ca-certificates.crt PIP_INDEX_URL="$PIP_INDEX_URL" pip install --no-cache-dir --only-binary=:all: -r requirements.txt

COPY . .

FROM python:3.14-slim AS runtime

WORKDIR /app
ARG PIP_INDEX_URL
RUN set -eux; \
	apt-get update && apt-get install -y --no-install-recommends \
		git \
		build-essential \
		curl \
		wget \
		ca-certificates \
		&& rm -rf /var/lib/apt/lists/*

ENV HF_HOME=/cache/huggingface

COPY --from=builder /app .

# Copy installed Python packages from builder (pip installs go to site-packages, not /app)
COPY --from=builder /usr/local/lib/python3.14 /usr/local/lib/python3.14
COPY --from=builder /usr/local/bin /usr/local/bin

EXPOSE 8000

CMD ["python", "entrypoint.py"]
