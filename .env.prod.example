DQ_S3_SSL_ENABLED=false
JAVA_TOOL_OPTIONS=
DQ_TEST_DATA_OUTPUT_PREFIX=
DQ_DELIVERY_OUTPUT_BUCKET=
TEST_DATA_MATERIALIZATION_QUEUE_KEY=dq-test-data:materialize
TEST_DATA_MATERIALIZATION_MAX_ROWS=5000

# Profile: kafka-consumer
# Kafka consumer worker — lightweight batch consumer that reads from any Kafka
# topic, flushes batches to S3 (compressed JSON) and/or PostgreSQL, then sleeps
# for a configurable delay before repeating.  Runs under the "workers" profile.
#
# Lifecycle: poll → flush → sleep → repeat (SIGTERM/SIGINT flushes remaining batch).
#
# Kafka connection
#   KAFKA_BOOTSTRAP_SERVERS    — broker list (docker-compose defaults to kafka:9094)
#   KAFKA_TOPIC                — topic to consume from (e.g. dq-made-easy.gx.violations)
#
# Consumer behaviour
KAFKA_CONSUMER_GROUP_ID=dq-consumer-violations
KAFKA_CONSUMER_POLL_TIMEOUT_SECONDS=5
KAFKA_CONSUMER_MAX_POLL_RECORDS=500
KAFKA_CONSUMER_LOOP_DELAY_SECONDS=30
KAFKA_CONSUMER_BATCH_SIZE=1000
KAFKA_AUTO_OFFSET_RESET=earliest
#
# S3 storage (optional — skip S3 writes if S3 env vars are unset)
KAFKA_CONSUMER_S3_BUCKET=dq-gx-exceptions
KAFKA_CONSUMER_S3_PREFIX=gx-exceptions
KAFKA_CONSUMER_S3_PATH_STYLE_ACCESS=true
#
# PostgreSQL storage (optional — skip DB writes if unset)
# Defaults to ${DQ_DB_INTERNAL_URL} in docker-compose when not overridden.
# KAFKA_CONSUMER_DB_URL=postgresql://postgres:password@db:5432/dq

# OpenTelemetry
