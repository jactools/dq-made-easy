# Data Quality Made Easy - Prod Environment Template
# Copy this file to .env.prod.local and fill the placeholder host, TLS files,
# and secrets for the canonical Debian production environment.
# This template assumes the single-edge ingress and path-prefix routing model
# described in docs/implementation-details/KONG_SINGLE_HTTPS_INGRESS_*.md.
# It models a single public host without subdomains.


ROOT_ENV_FILE=.env.prod.example

# ============================================
# IMAGE VERSIONS
# ============================================
# Production must pin exact application image tags.

DQ_BASE_TAG=0.10-566577b
DQ_API_TAG=0.10-7a9c018
DQ_ENGINE_TAG=0.10-b745035
DQ_PROFILING_TAG=0.10-950d35e
DQ_FRONTEND_TAG=0.10-bd861ee
DQ_KONG_TAG=0.10-18a1248
DQ_DB_TAG=0.10-49540d2
DQ_KEYCLOAK_TAG=0.10-af03ed8

# dq-made-easy-llm publish coordinates
DQ_LLM_REGISTRY=docker.io/
DQ_LLM_NAMESPACE=jacbeekers/
DQ_LLM_IMAGE=dq-made-easy-llm
# Replace with the published dq-made-easy-llm image tag before production use.
DQ_LLM_TAG=0.10-464630c
DQ_LLM_CHAT_PROVIDER=huggingface
DQ_LLM_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
# For Ollama-backed deployment, set DQ_LLM_CHAT_PROVIDER=ollama and configure both values below.
DQ_LLM_OLLAMA_BASE_URL=
DQ_LLM_OLLAMA_MODEL=gemma3:4b

# Example: Pin to specific versions for production
# DQ_BASE_TAG=0.10-566577b
# DQ_API_TAG=0.10-7a9c018
# DQ_ENGINE_TAG=0.10-b745035
# DQ_PROFILING_TAG=0.10-950d35e
# DQ_FRONTEND_TAG=0.10-bd861ee
# DQ_KONG_TAG=0.10-18a1248
# DQ_DB_TAG=0.10-49540d2
# DQ_KEYCLOAK_TAG=0.10-af03ed8

# ============================================
# IMAGE REGISTRY CONFIGURATION
# ============================================

REGISTRY=docker.io/
DOCKER_DOMAIN=docker.io

# Nexus Cloud registry/auth references
NEXUSCLOUD_HOSTNAME=__SET_NEXUSCLOUD_HOSTNAME__
NEXUSCLOUD_DNS=//${NEXUSCLOUD_HOSTNAME}
NEXUSCLOUD_REGISTRY=https://${NEXUSCLOUD_HOSTNAME}/repository/npmjs-org/
NEXUSCLOUD_NPM_REPOSITORY=gr-npm-84
NEXUSCLOUD_NPM_REGISTRY=https://${NEXUSCLOUD_HOSTNAME}/repository/${NEXUSCLOUD_NPM_REPOSITORY}/
NEXUSCLOUD_PYPI_GROUP_REPO=gr-pypi-36
NEXUSCLOUD_USERNAME=__SET_NEXUSCLOUD_USERNAME__
NEXUSCLOUD_PASSWORD=__SET_NEXUSCLOUD_PASSWORD__
NEXUSCLOUD_PASSWORD_BASE64=__SET_NEXUSCLOUD_PASSWORD_BASE64__

# DQ Services
DQ_BASE_REGISTRY=docker.io/
DQ_BASE_NAMESPACE=jacbeekers/
DQ_BASE_IMAGE=dq-made-easy-npm-base

DQ_API_REGISTRY=docker.io/
DQ_API_NAMESPACE=jacbeekers/
DQ_API_IMAGE=dq-made-easy-api

DQ_ENGINE_REGISTRY=docker.io/
DQ_ENGINE_NAMESPACE=jacbeekers/
DQ_ENGINE_IMAGE=dq-made-easy-engine

DQ_PROFILING_REGISTRY=docker.io/
DQ_PROFILING_NAMESPACE=jacbeekers/
DQ_PROFILING_IMAGE=dq-made-easy-profiling

DQ_FRONTEND_REGISTRY=docker.io/
DQ_FRONTEND_NAMESPACE=jacbeekers/
DQ_FRONTEND_IMAGE=dq-made-easy-frontend

DQ_KONG_REGISTRY=docker.io/
DQ_KONG_NAMESPACE=jacbeekers/
DQ_KONG_IMAGE=dq-made-easy-kong

DQ_DB_REGISTRY=docker.io/
DQ_DB_NAMESPACE=jacbeekers/
DQ_DB_IMAGE=dq-made-easy-db

DQ_KEYCLOAK_REGISTRY=docker.io/
DQ_KEYCLOAK_NAMESPACE=jacbeekers/
DQ_KEYCLOAK_IMAGE=dq-made-easy-keycloak

# ============================================
# THIRD-PARTY BASE IMAGES
# ============================================

# PostgreSQL
PG_REGISTRY=${REGISTRY}
PG_NAMESPACE=
PG_IMAGE=postgres
PG_TAG=15.8-alpine

# Keycloak
KEYCLOAK_REGISTRY=${REGISTRY}
KEYCLOAK_NAMESPACE=keycloak/
KEYCLOAK_IMAGE=keycloak
KEYCLOAK_TAG=22.0.1

# Node.js (for builds)
NODE_REGISTRY=${REGISTRY}
NODE_NAMESPACE=
NODE_IMAGE=node
NODE_TAG=20-bullseye-slim

# Nginx
NGINX_REGISTRY=${REGISTRY}
NGINX_NAMESPACE=
NGINX_IMAGE=nginx
NGINX_TAG=stable-alpine

# Redis
REDIS_REGISTRY=${REGISTRY}
REDIS_NAMESPACE=
REDIS_IMAGE=redis
REDIS_TAG=7-alpine

# ============================================
# APPLICATION CONFIGURATION
# ============================================

MAVEN_REPOSITORIES=
MKCERT_ROOT_CA=
INTERNAL_ROOT_CA=
INTERNAL_CORPORATE_ROOT_CA=
OTEL_JAVAAGENT_VERSION=2.16.0
COMPOSE_PROJECT_NAME=dq-made-easy-prod
PUBLIC_PRIMARY_HOST=__SET_PUBLIC_PRIMARY_HOST__

# Public host
PUBLIC_APEX_HOST=${PUBLIC_PRIMARY_HOST}
PUBLIC_CANONICAL_HOST=${PUBLIC_PRIMARY_HOST}

# Primary dq database URLs
DQ_DB_INTERNAL_URL=postgresql://supersecret:supersecret@db:5432/dq
DQ_DB_LOCAL_URL=postgresql://supersecret:supersecret@127.0.0.1:5432/dq
POSTGRES_USER=supersecret
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=dq

# Profile: llm
DQ_LLM_HOST_BIND=127.0.0.1
DQ_LLM_HOST_PORT=8123
DQ_LLM_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
DQ_LLM_DEVICE_MAP=auto
DQ_LLM_MAX_NEW_TOKENS=512
# Switch to meta-llama/Meta-Llama-3.1-8B-Instruct when the model access is available.

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
DB_HOST_BIND=127.0.0.1
DB_HOST_PORT=5432
REDIS_HOST_BIND=127.0.0.1
REDIS_HOST_PORT=6379

# Keycloak
KEYCLOAK_ADMIN=supersecret
KEYCLOAK_ADMIN_PASSWORD=supersecret
KEYCLOAK_ADMIN_USER=supersecret
KEYCLOAK_ADMIN_PASS=supersecret
KEYCLOAK_JACCLOUD_USERNAME=alice@jaccloud.nl
KEYCLOAK_JACCLOUD_PASSWORD=replace-with-current-generated-password-from-keycloak-seed-user-credentials-env
SMOKE_LOGIN_EMAIL=dq-admin@jaccloud.nl

# Kong Database
KONG_PG_HOST=kong-db
KONG_PG_DATABASE=kong
KONG_PG_USER=supersecret
KONG_PG_PASSWORD=supersecret

# API Configuration
ENVIRONMENT=production
NODE_ENV=production
DQ_API_INTERNAL_URL=http://api:4010
DQ_API_LOCAL_URL=http://127.0.0.1:4010

# How to generate a long random secret for APP_CONFIG_ENCRYPTION_KEY:
# python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"  
APP_CONFIG_ENCRYPTION_KEY=replace-with-a-long-random-secret
OIDC_REDIRECT_BASE_URL=https://${PUBLIC_PRIMARY_HOST}
EDGE_LOCAL_AIRFLOW_HOST=__SET_EDGE_LOCAL_AIRFLOW_HOST__
EDGE_MODE=public
EDGE_BIND_HOST=0.0.0.0
EDGE_PUBLIC_PORT=443
EDGE_SSL_CERTS_DIR=./tmp/certs
EDGE_SSL_CERT_FILE_NAME=__SET_EDGE_FULLCHAIN_FILE__
EDGE_SSL_KEY_FILE_NAME=__SET_EDGE_KEY_FILE__

API_HOST_BIND=127.0.0.1
API_HOST_PORT=4010
FRONTEND_HOST_BIND=127.0.0.1
FRONTEND_HTTPS_HOST_PORT=5173
KEYCLOAK_HTTP_HOST_BIND=127.0.0.1
KEYCLOAK_HTTP_HOST_PORT=8080
KEYCLOAK_HTTPS_HOST_BIND=127.0.0.1
KEYCLOAK_HTTPS_HOST_PORT=9444
KONG_PROXY_HOST_BIND=127.0.0.1
KONG_PROXY_HOST_PORT=9443
KONG_ADMIN_HOST_BIND=127.0.0.1
KONG_ADMIN_HOST_PORT=8001
KONG_MANAGER_HOST_BIND=127.0.0.1
KONG_MANAGER_HOST_PORT=8002
OPENMETADATA_HOST_BIND=127.0.0.1
OPENMETADATA_HOST_PORT=8585
GRAFANA_HOST_BIND=127.0.0.1
GRAFANA_HOST_PORT=3000
OPENMETADATA_DB_HOST_BIND=127.0.0.1
OPENMETADATA_DB_HOST_PORT=13306
OPENMETADATA_SEARCH_HOST_BIND=127.0.0.1
OPENMETADATA_SEARCH_HOST_PORT=19200
OPENMETADATA_INGESTION_HOST_BIND=127.0.0.1
OPENMETADATA_INGESTION_HOST_PORT=18080
LOKI_HOST_BIND=127.0.0.1
LOKI_HOST_PORT=3100
PROMETHEUS_HOST_BIND=127.0.0.1
PROMETHEUS_HOST_PORT=9090
TEMPO_HOST_BIND=127.0.0.1
TEMPO_HOST_PORT=3200
CONTAINER_METRICS_HOST_BIND=127.0.0.1
CONTAINER_METRICS_HOST_PORT=8881
PUSHGATEWAY_HOST_BIND=127.0.0.1
PUSHGATEWAY_HOST_PORT=9091
OTEL_GRPC_HOST_BIND=127.0.0.1
OTEL_GRPC_HOST_PORT=4317
OTEL_HTTP_HOST_BIND=127.0.0.1
OTEL_HTTP_HOST_PORT=4318
OTEL_JAEGER_HOST_BIND=127.0.0.1
OTEL_JAEGER_HOST_PORT=14250
OTEL_ZIPKIN_HOST_BIND=127.0.0.1
OTEL_ZIPKIN_HOST_PORT=9411
AISTOR_API_HOST_BIND=127.0.0.1
AISTOR_API_HOST_PORT=9222
AISTOR_CONSOLE_HOST_BIND=127.0.0.1
AISTOR_CONSOLE_HOST_PORT=9001
AISTOR_LICENSE_FILE=./tmp/aistor/minio.license
AISTOR_ROOT_USER=aistoradmin
AISTOR_ROOT_PASSWORD=aistoradmin
ZAMMAD_HOST_BIND=127.0.0.1

# Auth, gateway, and public browser URLs
KEYCLOAK_REALM=myrealm
KEYCLOAK_REALM_DISPLAY_NAME="My Realm"
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_TOKEN_REALM=master
KEYCLOAK_SYSTEM_ADMIN_USERNAME=supersecret
KEYCLOAK_SYSTEM_ADMIN_PASSWORD=supersecret
KEYCLOAK_INTERNAL_URL=http://keycloak:8080/iam
KEYCLOAK_LOCAL_URL=https://${PUBLIC_PRIMARY_HOST}/iam
KEYCLOAK_PUBLIC_HOSTNAME=${PUBLIC_PRIMARY_HOST}
KEYCLOAK_PUBLIC_URL=https://${PUBLIC_PRIMARY_HOST}/iam
KEYCLOAK_HTTP_RELATIVE_PATH=/iam
KEYCLOAK_HTTPS_KEYSTORE_PASSWORD=changeit

KONG_INTERNAL_URL=http://kong:8000
KONG_ADMIN_INTERNAL_URL=http://kong:8001
KONG_LOCAL_URL=https://${PUBLIC_PRIMARY_HOST}
KONG_PUBLIC_URL=https://${PUBLIC_PRIMARY_HOST}
KONG_ADMIN_LOCAL_URL=https://${PUBLIC_PRIMARY_HOST}/ops/kong
KONG_ADMIN_PUBLIC_URL=https://${PUBLIC_PRIMARY_HOST}/ops/kong
KONG_MANAGER_LOCAL_URL=https://${PUBLIC_PRIMARY_HOST}/ops/kong
KONG_MANAGER_PUBLIC_URL=https://${PUBLIC_PRIMARY_HOST}/ops/kong
TRUST_PROXY_AUTH=true
KONG_TRACING_INSTRUMENTATIONS=all
KONG_TRACING_SAMPLING_RATE=0.1

# SSO defaults (used when app_config DB rows are missing)
SSO_PROVIDER=keycloak
SSO_PUBLIC_ISSUER_URL=https://${PUBLIC_PRIMARY_HOST}/iam/realms/myrealm
SSO_INTERNAL_ISSUER_URL=http://keycloak:8080/iam/realms/myrealm
SSO_CLIENT_ID=dq-rules-ui
SSO_ALLOWED_CLIENT_IDS=dq-rules-ui,dq-made-easy-engine-gx-worker
SSO_ENABLED=true
ALLOW_LOCAL_AUTH=false

OPERATOR_LOGIN_EMAIL=operator@jaccloud.nl
AUDITOR_LOGIN_EMAIL=auditor@jaccloud.nl
REGULATOR_LOGIN_EMAIL=regulator@jaccloud.nl

# Profile: airflow
AIRFLOW_HOST_BIND=127.0.0.1
AIRFLOW_HOST_PORT=8088
AIRFLOW_FAB_CLIENT_ID=airflow
AIRFLOW_FAB_CLIENT_SECRET=changeme
DQ_AIRFLOW_BASE_URL=http://api:4010
DQ_AIRFLOW_ISSUER_URL=${SSO_INTERNAL_ISSUER_URL}
DQ_AIRFLOW_CLIENT_ID=${SSO_CLIENT_ID}
DQ_AIRFLOW_USERNAME=${OPERATOR_LOGIN_EMAIL:-operator@jaccloud.nl}
DQ_AIRFLOW_PASSWORD=${OPERATOR_LOGIN_PASSWORD:-replace-with-current-generated-password-from-keycloak-seed-user-credentials-env}
DQ_AIRFLOW_RUN_PLAN_ID=
DQ_AIRFLOW_SOURCE_PIPELINE=airflow
DQ_AIRFLOW_WAIT_TIMEOUT_SECONDS=1800
DQ_AIRFLOW_POLL_INTERVAL_SECONDS=5

# Profiling Worker
PROFILING_WORKER_CONCURRENCY=2
DQ_ENGINE_OIDC_CLIENT_ID=dq-made-easy-engine-gx-worker
DQ_ENGINE_INTERNAL_URL=http://dq-made-easy-engine:8000
DQ_ENGINE_LOCAL_URL=http://127.0.0.1:8003
DQ_ENGINE_MAX_ROWS=100000
DQ_LOG_LEVEL=INFO
GX_EXECUTION_QUEUE_KEY=dq-gx:execution-dispatch
GX_JOIN_PAIR_MATERIALIZATION_QUEUE_KEY=dq-gx:join-pair-materialize
PROFILING_QUEUE_KEY=dq-made-easy-profiling:local-queue
NATURAL_LANGUAGE_DRAFT_QUEUE_KEY=dq-natural-language-draft:queue
DQ_SPARK_MASTER=local[*]
DQ_SPARK_DRIVER_MEMORY=2g
DQ_SPARK_EXECUTOR_MEMORY=2g
DQ_SPARK_DRIVER_MAX_RESULT_SIZE=512m
DQ_ENGINE_SKIP_SPARK_WARMUP=false
DELIVERY_SEED_SKIP_SPARK_WARMUP=true
DQ_S3_ENDPOINT=
DQ_S3_ACCESS_KEY=
DQ_S3_SECRET_KEY=
DQ_S3_REGION=
DQ_S3_PATH_STYLE_ACCESS=true
DQ_S3_SSL_ENABLED=false
JAVA_TOOL_OPTIONS=
DQ_TEST_DATA_OUTPUT_PREFIX=
DQ_DELIVERY_OUTPUT_BUCKET=
TEST_DATA_MATERIALIZATION_QUEUE_KEY=dq-test-data:materialize
TEST_DATA_MATERIALIZATION_MAX_ROWS=5000

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://dq-otel-collector:4317
OTEL_TRACES_SAMPLER_ARG=0.1

# Repo-built OpenMetadata helper images
DQ_OPENMETADATA_DB_REGISTRY=docker.io/
DQ_OPENMETADATA_DB_NAMESPACE=jacbeekers/
DQ_OPENMETADATA_DB_IMAGE=dq-made-easy-openmetadata-db
DQ_OPENMETADATA_DB_TAG=0.10-e62c46b

DQ_OPENMETADATA_SERVER_REGISTRY=docker.io/
DQ_OPENMETADATA_SERVER_NAMESPACE=jacbeekers/
DQ_OPENMETADATA_SERVER_IMAGE=dq-made-easy-openmetadata
DQ_OPENMETADATA_SERVER_TAG=0.10-cae0cf2

DQ_METADATA_CONFIGURE_REGISTRY=docker.io/
DQ_METADATA_CONFIGURE_NAMESPACE=jacbeekers/
DQ_METADATA_CONFIGURE_IMAGE=dq-made-easy-metadata-configure
DQ_METADATA_CONFIGURE_TAG=0.10-600ba08

# Frontend
UI_VITE_LOCAL_URL=https://${PUBLIC_PRIMARY_HOST}
UI_NGINX_LOCAL_URL=https://${PUBLIC_PRIMARY_HOST}
VITE_SSO_PROVIDER=keycloak
VITE_SSO_CLIENT_ID=dq-rules-ui
VITE_ALLOW_LOCAL_AUTH=${ALLOW_LOCAL_AUTH}
VITE_OTEL_ENABLED=false
VITE_OTEL_ENDPOINT=

# Metadata and observability public URLs
OPENMETADATA_REGISTRY=docker.io/
OPENMETADATA_NAMESPACE=
OPENMETADATA_IMAGE=openmetadata/server
OPENMETADATA_TAG=1.12.4
OPENMETADATA_SEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch
OPENMETADATA_SEARCH_TAG=9.3.0
OPENMETADATA_INGESTION_REGISTRY=openmetadata/
OPENMETADATA_INGESTION_NAMESPACE=
OPENMETADATA_INGESTION_IMAGE=ingestion
CATALOG_PROVIDER=openmetadata
CATALOG_ENDPOINT=https://${PUBLIC_PRIMARY_HOST}/metadata/api
CATALOG_API_KEY=
CATALOG_OIDC_ISSUER=http://keycloak:8080/iam/realms/myrealm
CATALOG_OIDC_TOKEN_URL=http://keycloak:8080/iam/realms/myrealm/protocol/openid-connect/token
CATALOG_OIDC_CLIENT_ID=openmetadata
CATALOG_OIDC_CLIENT_SECRET=
CATALOG_OIDC_SCOPE=
CATALOG_OIDC_USERNAME=dq-admin@jaccloud.nl
CATALOG_OIDC_PASSWORD=supersecret
OPENMETADATA_CALLBACK=https://${PUBLIC_PRIMARY_HOST}/metadata/callback
OPENMETADATA_BASE_PATH=/metadata
OPENMETADATA_PUBLIC_URL=https://${PUBLIC_PRIMARY_HOST}/metadata
OPENMETADATA_USE_FORWARDED_HEADERS=true
OPENMETADATA_VERSION=1.12.4
OM_DB_ROOT_PASSWORD=openmetadata_root
OM_DB_NAME=supersecret
OM_DB_USER=supersecret
OM_DB_PASSWORD=supersecret
OM_DB_SSL_MODE=disable
OM_AIRFLOW_SECRET_KEY=openmetadata_airflow_secret
OM_AUTHENTICATION_PROVIDER=custom-oidc
OM_OIDC_PROVIDER_NAME=Keycloak
OM_AUTHORIZER_ADMIN_PRINCIPALS=[dq-admin]
OM_AUTHORIZER_PRINCIPAL_DOMAIN=jaccloud.nl
OM_AUTHENTICATION_AUTHORITY=https://${PUBLIC_PRIMARY_HOST}/iam/realms/myrealm
OM_AUTHENTICATION_CLIENT_ID=openmetadata
OM_AUTHENTICATION_CALLBACK_URL=https://${PUBLIC_PRIMARY_HOST}/metadata/callback
OM_AUTHENTICATION_DISCOVERY_URI=https://${PUBLIC_PRIMARY_HOST}/iam/realms/myrealm/.well-known/openid-configuration
OM_AUTHENTICATION_RESPONSE_TYPE=code
OM_AUTHENTICATION_PUBLIC_KEYS=[http://keycloak:8080/iam/realms/myrealm/protocol/openid-connect/certs,https://openmetadata-server:8585/metadata/api/v1/system/config/jwks]
OM_ENABLE_AUTO_REDIRECT=false
KEYCLOAK_USER_PASSWORD=${KEYCLOAK_JACCLOUD_PASSWORD}
OPENMETADATA_OIDC_SEED_USERNAME=replace-with-smoke-login-email
OPENMETADATA_OIDC_SEED_PASSWORD=replace-with-current-generated-password-from-keycloak-seed-user-credentials-env
SEED_ALL=false
START_METADATA=true
START_METADATA_INGESTION=false
GRAFANA_PUBLIC_DOMAIN=${PUBLIC_PRIMARY_HOST}
GRAFANA_PUBLIC_URL=https://${PUBLIC_PRIMARY_HOST}/observability
GRAFANA_SERVE_FROM_SUB_PATH=true

# Optional support stack defaults
ZAMMAD_IMAGE=ghcr.io/zammad/zammad:7.0.1-0000
ZAMMAD_MEMCACHE_SERVERS=zammad-memcached:11211
ZAMMAD_POSTGRES_VERSION=17.9-alpine
ZAMMAD_POSTGRES_DB=zammad_production
ZAMMAD_POSTGRES_HOST=zammad-postgresql
ZAMMAD_POSTGRES_USER=supersecret
ZAMMAD_POSTGRES_PASSWORD=supersecret
ZAMMAD_POSTGRES_PORT=5432
ZAMMAD_POSTGRESQL_OPTIONS=?pool=50
ZAMMAD_REDIS_VERSION=8.6.2-alpine
ZAMMAD_REDIS_URL=redis://redis:6379/1
ZAMMAD_MEMCACHE_VERSION=1.6.41-alpine
ZAMMAD_ELASTICSEARCH_ENABLED=true
ZAMMAD_ELASTICSEARCH_HOST=openmetadata-search
ZAMMAD_ELASTICSEARCH_PORT=9200
ZAMMAD_ELASTICSEARCH_SCHEMA=http
ZAMMAD_ELASTICSEARCH_NAMESPACE=zammad
ZAMMAD_ELASTICSEARCH_SSL_VERIFY=true
ZAMMAD_NGINX_PORT=8080
ZAMMAD_NGINX_SERVER_NAME=${PUBLIC_PRIMARY_HOST}
ZAMMAD_NGINX_SERVER_SCHEME=https
ZAMMAD_RAILS_TRUSTED_PROXIES=
ZAMMAD_HTTP_TYPE=https
ZAMMAD_FQDN=${PUBLIC_PRIMARY_HOST}
ZAMMAD_PUBLIC_URL=https://${ZAMMAD_FQDN}
ZAMMAD_WEB_CONCURRENCY=2
ZAMMAD_EXPOSE_PORT=8088
TZ=UTC

# ============================================
# DOCKER HUB CONFIGURATION (Optional)
# ============================================
# Only needed for publishing images to Docker Hub
# Create token at: https://hub.docker.com/settings/security

DOCKER_HUB_USERNAME=
DOCKER_HUB_TOKEN=

DQ_DATA_DEFINITION_EVENT_TIMEOUT_SECONDS=900
DQ_DATA_DEFINITION_LLM_TIMEOUT_SECONDS=900
DQ_SMOKE_MATERIALIZATION_TIMEOUT_SECONDS=900
DQ_RULE_E2E_MATERIALIZATION_TIMEOUT_SECONDS=900
DQ_RULE_E2E_GX_TIMEOUT_SECONDS=900
DQ_LLM_MAX_RETRIES=3
DQ_MCP_API_BASE_URL=${DQ_API_LOCAL_URL}/api
DQ_MCP_API_TOKEN=
DQ_MCP_API_TIMEOUT_SECONDS=30
