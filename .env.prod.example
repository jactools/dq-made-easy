ZAMMAD_WEB_CONCURRENCY=2
ZAMMAD_EXPOSE_PORT=8088
ZAMMAD_SSL_CERT_FILE_NAME=__SET_ZAMMAD_SSL_CERT_FILE_NAME__
ZAMMAD_SSL_KEY_FILE_NAME=__SET_ZAMMAD_SSL_KEY_FILE_NAME__

# Profile: openmetadata
OPENMETADATA_BASE_PATH=/
OPENMETADATA_PUBLIC_URL=https://${PUBLIC_PRIMARY_HOST}:8585
OPENMETADATA_SERVER_URL=https://openmetadata-server:8585${OPENMETADATA_BASE_PATH:-/}/api
OPENMETADATA_VERIFY_SSL=true
OPENMETADATA_CA_BUNDLE=/etc/openmetadata/certs/internal-ca-bundle.pem
OPENMETADATA_USE_FORWARDED_HEADERS=false
TZ=UTC

# ============================================
# DOCKER HUB CONFIGURATION (Optional)
# ============================================
# Only needed for publishing images to Docker Hub
# Create token at: https://hub.docker.com/settings/security

DOCKER_HUB_USERNAME=
DOCKER_HUB_TOKEN=

DQ_DATA_DEFINITION_EVENT_TIMEOUT_SECONDS=900
DQ_DATA_DEFINITION_LLM_TIMEOUT_SECONDS=900
DQ_SMOKE_MATERIALIZATION_TIMEOUT_SECONDS=900
DQ_RULE_E2E_MATERIALIZATION_TIMEOUT_SECONDS=900
DQ_RULE_E2E_GX_TIMEOUT_SECONDS=900
DQ_LLM_MAX_RETRIES=3
DQ_MCP_API_BASE_URL=${DQ_API_LOCAL_URL}/api
DQ_MCP_API_TOKEN=
DQ_MCP_API_TIMEOUT_SECONDS=30
