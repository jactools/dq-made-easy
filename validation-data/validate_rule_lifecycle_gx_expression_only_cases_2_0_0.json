[
  {
    "case_id": "plausible_transaction_amount_by_currency",
    "dimension": "accuracy",
    "version_id": "dov-9",
    "data_object_id": "do-4",
    "primary_key_fields": [
      "transaction_id"
    ],
    "assign_attribute_names": [
      "amount",
      "currency"
    ],
    "materialize_attribute_names": [
      "transaction_id",
      "amount",
      "currency"
    ],
    "dsl": {
      "schema_version": "2.0.0",
      "rule": {
        "kind": "custom_query_assertion",
        "scope": {
          "dataset": {
            "data_object_id": "do-4"
          }
        },
        "measure": {
          "type": "query",
          "query_language": "sql",
          "query": "(currency = 'USD' AND amount >= 0 AND amount <= 100000) OR (currency = 'EUR' AND amount >= 0 AND amount <= 90000)"
        },
        "expectation": {
          "type": "threshold",
          "operator": "gte",
          "value": 100,
          "unit": "percent"
        },
        "evidence": {
          "failed_rows": {
            "mode": "sample",
            "limit": 25,
            "include_row_identifier": true,
            "include_primary_key": true
          },
          "emit_compiled_artifact": true,
          "emit_generated_sql": false
        },
        "operations": {
          "severity": "critical",
          "preferred_engines": [
            "gx",
            "sql"
          ],
          "fail_if_not_native": false
        }
      }
    }
  },
