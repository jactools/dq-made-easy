    "case_id": "join_consistency_customer_contact_email_and_actuality_align",
    "dimension": "consistency",
    "version_id": "dov-3",
    "data_object_id": "do-1",
    "primary_key_fields": [
      "customer_id"
    ],
    "assign_attribute_names": [
      "customer_id",
      "email",
      "created_at"
    ],
    "dsl": {
      "schema_version": "2.0.0",
      "rule": {
        "kind": "reconciliation_assertion",
        "scope": {
          "comparison": {
            "left": {
              "data_object_id": "do-1",
              "data_object_version_id": "dov-3"
            },
            "right": {
              "data_object_id": "do-2",
              "data_object_version_id": "dov-23"
            },
            "join_keys": [
              {
                "left_column": "customer_id",
                "right_column": "customer_id"
              }
            ]
          }
        },
        "measure": {
          "type": "query",
          "query_language": "sql",
          "query": "customer_id = rhs.customer_id AND LOWER(email) = LOWER(rhs.email_address) AND ABS(TIMESTAMPDIFF(HOUR, created_at, rhs.last_contacted)) <= 24"
        },
        "expectation": {
          "type": "threshold",
          "operator": "gte",
          "value": 100,
