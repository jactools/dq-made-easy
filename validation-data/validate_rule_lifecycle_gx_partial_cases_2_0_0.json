[
  {
    "case_id": "freshness_customer_created_at_within_1_day",
    "dimension": "timeliness",
    "version_id": "dov-3",
    "data_object_id": "do-1",
    "primary_key_fields": [
      "customer_id"
    ],
    "assign_attribute_names": [
      "created_at"
    ],
    "materialize_attribute_names": [
      "customer_id",
      "created_at"
    ],
    "dsl": {
      "schema_version": "2.0.0",
      "rule": {
        "kind": "freshness_assertion",
        "scope": {
          "dataset": {
            "data_object_id": "do-1"
          }
        },
        "measure": {
          "type": "metric",
          "metric": "freshness_age",
          "subject": {
            "column": "created_at"
          }
        },
        "expectation": {
          "type": "threshold",
          "operator": "lte",
          "value": "P1D",
          "unit": "duration"
        },
        "evidence": {
          "failed_rows": {
            "mode": "sample",
            "limit": 25,
            "include_row_identifier": true,
            "include_primary_key": true
          },
          "emit_compiled_artifact": true,
          "emit_generated_sql": false
        },
        "operations": {
          "severity": "critical",
          "preferred_engines": [
            "gx",
            "sql"
          ],
          "fail_if_not_native": false
        }
      }
    }
  },
